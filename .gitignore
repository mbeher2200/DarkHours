# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
Sky/
Predictor/

# Local editor and tool settings
.claude/
.impeccable/
.github/skills/

# macOS
.DS_Store

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Logs
*.log

# Test caches
.pytest_cache/

# Light-pollution DB experiment (generated artefacts — not for version control)
tools/lp_db/

# Environment / secrets — local config and AWS credentials (never commit)
.env
.env.*
!.env.example
*.pem

# Local dev convenience script
dev.sh

# Geospatial rasters — large source/generated COGs live outside the repo
# (the bundled de421.bsp ephemeris is .bsp, intentionally NOT matched here)
*.tif
*.tiff

# PADUS raw geodatabase and metadata (too large to distribute; run build_padus_index.py to regenerate)
Temp/

# Generated spatial index artefacts (derived from PADUS; do not distribute)
# darkhours_padus_h3.npz (~3 MB) IS the committed runtime index — Docker builds
# require it. The .parquet is kept as the build/verify reference source.
# Raw/intermediate files (GDB, full vector parquet, shapefiles) are excluded.
cache/*
!cache/darkhours_padus_h3.parquet
!cache/darkhours_padus_h3.npz
# Routable OSM POI index (derived from OpenStreetMap, ODbL — © OpenStreetMap
# contributors). IS the committed runtime index; Docker builds COPY it. Built by
# scripts/osm_poi_builder.py from a Geofabrik .osm.pbf. See docs/OSM_POI_INDEX.md.
!cache/osm_pois.npz

# AWS CDK infrastructure build artefacts (added ahead of M4)
cdk.out/
.cdk.staging/

# Postman: environment files can carry the live CloudFront URL — keep them out of the
# public repo. Ignore ALL env files, then re-include only the Local (localhost) one.
# The collection (PyNightSky.postman_collection.json) is always committed.
postman/*.postman_environment.json
!postman/PyNightSky.local.postman_environment.json

# CDK Lambda staging dirs (built at synth)
cdk/.warmer_build/
cdk/.worker_build/
PRODUCT.md
